# Copy this file to `.env` and fill in only the providers you want to use.
# `session-to-song doctor` will detect what is available and show the resolved provider/model.

# LLM providers
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
OLLAMA_HOST=

# Music providers
# Supported live audio paths in this repo: Google/Gemini, MiniMax, and Comfy.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=
COMFY_API_KEY=
COMFY_CLOUD_API_KEY=
COMFY_MODE=local
COMFY_BASE_URL=
COMFY_MUSIC_WORKFLOW_PATH=
COMFY_MUSIC_PROMPT_NODE_ID=
COMFY_MUSIC_PROMPT_INPUT_NAME=text
COMFY_MUSIC_OUTPUT_NODE_ID=
COMFY_MUSIC_TIMEOUT_MS=
COMFY_MUSIC_POLL_INTERVAL_MS=

# Notes:
# - `GOOGLE_API_KEY` and `GEMINI_API_KEY` are treated as equivalents for Google/Gemini providers.
# - `OLLAMA_HOST` can point to a local server like http://localhost:11434.
# - `config/user.json` stays local and is already gitignored.
